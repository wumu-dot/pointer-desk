# ============================================================
# pointer-desk .gitignore
# ============================================================

# --- CodeGraph index ---
.codegraph/

# --- Build outputs ---
build/
Build/
*.o
*.obj
*.crf
*.d
*.dep
*.axf
*.elf
*.hex
*.bin
*.lnp
*.map
*.build_log.htm
*.htm
*.lst
*.bak

# --- Keil MDK user-specific files ---
*.uvguix.*
*.uvoptx
*.Administrator
*.Scif_5.30

# --- CubeMX generated (tracked separately if needed) ---
# .mxproject is already tracked; uncomment if you want to untrack:
# .mxproject

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Python ---
__pycache__/
*.pyc

# --- Misc ---
*.tmp
*.log
